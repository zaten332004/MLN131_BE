# SQL Server (required)
# Must meet SQL Server password policy (>= 8 chars, upper/lower/digit/special).
# Note: `SA_PASSWORD` cannot be `12345` (SQL Server enforces strong passwords for `sa`).
SA_PASSWORD=ChangeMe_123!

# App DB login (used by backend connection string)
DB_USER=mln131
DB_PASSWORD=12345

# JWT (required)
# Use a long random secret.
JWT_SIGNING_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Optional
GEMINI_API_KEY=

# Optional seed admin on first run
SEED_ADMIN_EMAIL=Admin@example.com
SEED_ADMIN_PASSWORD=Admin123!

